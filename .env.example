# ===========================================
# Knoggin Configuration
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# -------------------------------------------
# Optional - defaults shown
# -------------------------------------------

# Data store hosts (only change if running outside Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687

# GPU acceleration
# Set to "true" to enable GPU for embeddings and NER
KNOGGIN_GPU=false

# Thread pool workers (increase if you have more CPU cores)
KNOGGIN_WORKERS=4

# Note: LLM API keys, model selection, and user name 
# are configured through the app's onboarding UI,
# not through environment variables.